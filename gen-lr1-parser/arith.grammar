
| import Backend.AST
| import Backend.DefaultLexer

start Expr

Expr = e:Expr "+" f:Factor { Add pos e f }
Expr = f:Factor            { Factor pos f }

Factor = f:Factor "*" t:Term { Mult pos f t }
Factor = t:Term              { Term pos t }

Term = n:"<num>"      { Number pos n }
Term = "(" e:Expr ")" { Group  pos e }

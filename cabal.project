
packages:
  ./gen-lr1-parser
  ./lr1-parser-pos
  ./lr1-parser-example
  ./lr1-parser-lexeme
  ./lr1-parser-default-lexer
  ./data-map-monoidal
  ./control-fixpoint
  ./lr1-pretty

program-options
  ghc-options:
    -freverse-errors
    -O0
    -j
    -fdiagnostics-color=always
    -Werror
    -Wno-orphans
